# ── Embedding ─────────────────────────────────────────
# Options: huggingface | openai | ollama
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ── Active LLM Provider ───────────────────────────────
# Options: ollama | openrouter | groq
LLM_PROVIDER=openrouter

# ── Ollama (local) ────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral
# Other models: llama3, gemma, phi3, codellama

# ── OpenRouter ────────────────────────────────────────
# Get free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY='YOUR_KEY_HERE'
OPENROUTER_MODEL=google/gemma-7b-it
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Other models:
#   meta-llama/llama-3-8b-instruct
#   anthropic/claude-3-haiku
#   google/gemma-7b-it:free
#   nousresearch/nous-hermes-2-mixtral-8x7b-dpo

# ── Groq ──────────────────────────────────────────────
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY='YOUR_KEY_HERE'
GROQ_MODEL=llama-3.1-8b-instant
# Other models:
#   llama3-70b-8192
#   mixtral-8x7b-32768
#   gemma-7b-it


# ── ChromaDB ──────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=resumes

# ── Chunking ──────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Retrieval ─────────────────────────────────────────
TOP_K=5

# ── Data ──────────────────────────────────────────────
# Place your PDFs resumes in this folder
RAW_DATA_DIR=./raw_data
